{
  "name": "QA & Testing Agent",
  "description": "负责测试编写、测试执行和质量保证",
  "label": "qa-agent",
  "runtime": "subagent",
  "mode": "session",
  "model": "claude-web/claude-sonnet-4-6",
  "thinking": "normal",
  "timeoutSeconds": 1800,
  "task": "You are a QA and testing agent. Your role is to write tests, execute test suites, analyze test coverage, and ensure code quality.",
  "systemPrompt": "你是质量保证和测试专家，负责确保代码质量和可靠性。",
  "communication": {
    "canSendTo": [
      "orchestrator",
      "coding-agent"
    ],
    "canReceiveFrom": [
      "orchestrator"
    ]
  },
  "tools": [
    "broadcast_to_agents",
    "generate_test_report",
    "get_task",
    "log_error",
    "log_info",
    "process_messages",
    "receive_messages",
    "run_tests",
    "send_notification",
    "send_to_agent",
    "update_task_status"
  ],
  "toolConfig": {
    "run_tests": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "run_tests",
      "description": "运行测试套件",
      "parameters": [
        "project-dir",
        "test-type"
      ],
      "usage": "run_tests <project-dir> [unit|integration|e2e]"
    },
    "generate_test_report": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "generate_test_report",
      "description": "生成测试报告",
      "parameters": [
        "project-dir",
        "output-file"
      ],
      "usage": "generate_test_report <project-dir> [output-file]"
    },
    "log_info": {
      "script": "scripts/lib/common.sh",
      "function": "log_info",
      "description": "记录信息日志",
      "usage": "log_info <message>"
    },
    "log_error": {
      "script": "scripts/lib/common.sh",
      "function": "log_error",
      "description": "记录错误日志",
      "usage": "log_error <message>"
    },
    "send_notification": {
      "script": "scripts/lib/notify.sh",
      "function": "send_notification",
      "description": "发送通知",
      "usage": "send_notification <channel> <message> [title]"
    },
    "get_task": {
      "script": "scripts/lib/common.sh",
      "function": "get_task",
      "description": "获取任务信息",
      "parameters": [
        "task-id"
      ],
      "usage": "get_task <task-id>"
    },
    "update_task_status": {
      "script": "scripts/lib/common.sh",
      "function": "update_task_status",
      "description": "更新任务状态",
      "parameters": [
        "task-id",
        "status"
      ],
      "usage": "update_task_status <task-id> <status>"
    }
  },
  "capabilities": [
    "test-generation",
    "test-execution",
    "coverage-analysis",
    "quality-metrics"
  ],
  "persistence": {
    "storeMemory": true,
    "memoryFile": "memory/qa-memory.md"
  }
}
