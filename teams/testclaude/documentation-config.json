{
  "name": "Documentation Agent",
  "description": "负责技术文档编写、API文档生成和维护",
  "label": "documentation-agent",
  "runtime": "subagent",
  "mode": "session",
  "model": "claude-web/claude-sonnet-4-6",
  "thinking": "normal",
  "timeoutSeconds": 1200,
  "task": "You are a technical documentation agent. Your role is to write, update, and maintain documentation.",
  "systemPrompt": "你是技术文档专家，负责编写和维护高质量的技术文档。",
  "communication": {
    "canSendTo": [
      "orchestrator"
    ],
    "canReceiveFrom": [
      "orchestrator",
      "coding-agent"
    ]
  },
  "tools": [
    "broadcast_to_agents",
    "generate_readme",
    "log_error",
    "log_info",
    "process_messages",
    "read_file",
    "receive_messages",
    "send_notification",
    "send_to_agent",
    "write_file"
  ],
  "toolConfig": {
    "generate_readme": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "generate_readme",
      "description": "生成 README 文档",
      "parameters": [
        "project-name",
        "description",
        "output-file"
      ],
      "usage": "generate_readme <project-name> <description> [output-file]"
    },
    "log_info": {
      "script": "scripts/lib/common.sh",
      "function": "log_info",
      "description": "记录信息日志",
      "usage": "log_info <message>"
    },
    "log_error": {
      "script": "scripts/lib/common.sh",
      "function": "log_error",
      "description": "记录错误日志",
      "usage": "log_error <message>"
    },
    "send_notification": {
      "script": "scripts/lib/notify.sh",
      "function": "send_notification",
      "description": "发送通知",
      "usage": "send_notification <channel> <message> [title]"
    },
    "write_file": {
      "script": "scripts/lib/common.sh",
      "function": "write_file",
      "description": "写入文件",
      "parameters": [
        "file",
        "content"
      ],
      "usage": "write_file <file> <content>"
    },
    "read_file": {
      "script": "scripts/lib/common.sh",
      "function": "read_file",
      "description": "读取文件",
      "parameters": [
        "file"
      ],
      "usage": "read_file <file>"
    }
  },
  "capabilities": [
    "doc-generation",
    "api-docs",
    "readme-updates",
    "comment-enhancement"
  ],
  "persistence": {
    "storeMemory": true,
    "memoryFile": "memory/documentation-memory.md"
  }
}
