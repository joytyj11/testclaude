{
  "name": "DevOps Agent",
  "description": "负责CI/CD配置、部署脚本和环境管理",
  "label": "devops-agent",
  "runtime": "subagent",
  "mode": "session",
  "model": "claude-web/claude-sonnet-4-6",
  "thinking": "normal",
  "timeoutSeconds": 1800,
  "task": "You are a DevOps agent. Your role is to manage CI/CD pipelines, deployment scripts, and infrastructure as code.",
  "systemPrompt": "你是 DevOps 专家，负责自动化部署、CI/CD 流水线和基础设施管理。",
  "communication": {
    "canSendTo": [
      "orchestrator"
    ],
    "canReceiveFrom": [
      "orchestrator",
      "coding-agent"
    ]
  },
  "tools": [
    "broadcast_to_agents",
    "ensure_dir",
    "generate_dockerfile",
    "generate_github_workflow",
    "log_error",
    "log_info",
    "process_messages",
    "receive_messages",
    "send_notification",
    "send_to_agent",
    "write_file"
  ],
  "toolConfig": {
    "generate_github_workflow": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "generate_github_workflow",
      "description": "生成 GitHub Actions 工作流",
      "parameters": [
        "workflow-name",
        "output-file"
      ],
      "usage": "generate_github_workflow <workflow-name> [output-file]"
    },
    "generate_dockerfile": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "generate_dockerfile",
      "description": "生成 Dockerfile",
      "parameters": [
        "output-file"
      ],
      "usage": "generate_dockerfile [output-file]"
    },
    "log_info": {
      "script": "scripts/lib/common.sh",
      "function": "log_info",
      "description": "记录信息日志",
      "usage": "log_info <message>"
    },
    "log_error": {
      "script": "scripts/lib/common.sh",
      "function": "log_error",
      "description": "记录错误日志",
      "usage": "log_error <message>"
    },
    "send_notification": {
      "script": "scripts/lib/notify.sh",
      "function": "send_notification",
      "description": "发送通知",
      "usage": "send_notification <channel> <message> [title]"
    },
    "ensure_dir": {
      "script": "scripts/lib/common.sh",
      "function": "ensure_dir",
      "description": "确保目录存在",
      "parameters": [
        "dir"
      ],
      "usage": "ensure_dir <dir>"
    },
    "write_file": {
      "script": "scripts/lib/common.sh",
      "function": "write_file",
      "description": "写入文件",
      "parameters": [
        "file",
        "content"
      ],
      "usage": "write_file <file> <content>"
    }
  },
  "capabilities": [
    "ci-cd-config",
    "deployment-scripts",
    "docker-config",
    "infrastructure-as-code"
  ],
  "persistence": {
    "storeMemory": true,
    "memoryFile": "memory/devops-memory.md"
  }
}
