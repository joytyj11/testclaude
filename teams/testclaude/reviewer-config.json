{
  "name": "Code Review Agent",
  "description": "负责代码审查、质量检查和最佳实践验证",
  "label": "reviewer-agent",
  "runtime": "subagent",
  "mode": "session",
  "model": "claude-web/claude-sonnet-4-6",
  "thinking": "normal",
  "timeoutSeconds": 1800,
  "task": "You are a code review agent. Your role is to review code changes, ensure they follow best practices, identify potential issues, and provide constructive feedback.",
  "systemPrompt": "你是代码审查专家，负责审查代码变更并提供改进建议。",
  "communication": {
    "canSendTo": [
      "orchestrator",
      "coding-agent"
    ],
    "canReceiveFrom": [
      "orchestrator",
      "coding-agent"
    ]
  },
  "tools": [
    "add_review_comment",
    "broadcast_to_agents",
    "generate_review_report",
    "get_ci_status",
    "get_pr_info",
    "get_pr_status",
    "log_error",
    "log_info",
    "process_messages",
    "receive_messages",
    "review_pr",
    "send_notification",
    "send_to_agent"
  ],
  "toolConfig": {
    "generate_review_report": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "generate_review_report",
      "description": "生成代码审查报告",
      "parameters": [
        "repo",
        "pr-number",
        "output-file"
      ],
      "usage": "generate_review_report <repo> <pr-number> [output-file]"
    },
    "add_review_comment": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "add_review_comment",
      "description": "添加 PR 审查评论",
      "parameters": [
        "repo",
        "pr-number",
        "comment"
      ],
      "usage": "add_review_comment <repo> <pr-number> <comment>"
    },
    "review_pr": {
      "script": "scripts/lib/github.sh",
      "function": "review_pr",
      "description": "提交 PR 审查",
      "parameters": [
        "repo",
        "pr-number",
        "review-type",
        "body"
      ],
      "usage": "review_pr <repo> <pr-number> <APPROVE|REQUEST_CHANGES|COMMENT> <body>"
    },
    "get_pr_info": {
      "script": "scripts/lib/github.sh",
      "function": "get_pr_info",
      "description": "获取 PR 详细信息",
      "parameters": [
        "repo",
        "pr-number"
      ],
      "usage": "get_pr_info <repo> <pr-number>"
    },
    "get_pr_status": {
      "script": "scripts/lib/github.sh",
      "function": "get_pr_status",
      "description": "获取 PR 状态",
      "parameters": [
        "repo",
        "pr-number"
      ],
      "usage": "get_pr_status <repo> <pr-number>"
    },
    "get_ci_status": {
      "script": "scripts/lib/github.sh",
      "function": "get_ci_status",
      "description": "获取 CI 状态",
      "parameters": [
        "repo",
        "pr-number"
      ],
      "usage": "get_ci_status <repo> <pr-number>"
    },
    "log_info": {
      "script": "scripts/lib/common.sh",
      "function": "log_info",
      "description": "记录信息日志",
      "parameters": [
        "message"
      ],
      "usage": "log_info <message>"
    },
    "log_error": {
      "script": "scripts/lib/common.sh",
      "function": "log_error",
      "description": "记录错误日志",
      "parameters": [
        "message"
      ],
      "usage": "log_error <message>"
    },
    "send_notification": {
      "script": "scripts/lib/notify.sh",
      "function": "send_notification",
      "description": "发送通知到外部频道",
      "parameters": [
        "channel",
        "message",
        "title"
      ],
      "usage": "send_notification <channel> <message> [title]"
    }
  },
  "capabilities": [
    "code-review",
    "quality-check",
    "security-scan",
    "performance-analysis",
    "best-practices"
  ],
  "persistence": {
    "storeMemory": true,
    "memoryFile": "memory/reviewer-memory.md"
  }
}
