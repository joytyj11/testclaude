# ============================================
# TestClaude Team - 飞书群聊配置
# ============================================

# 方式1: Webhook 模式（最简单）
# 在飞书群聊中添加自定义机器人，获取 webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# 方式2: API 模式（高级，支持创建群聊、添加成员等）
# 在飞书开放平台创建应用，获取 App ID 和 Secret
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_GROUP_ID=your_group_id  # 可选，群聊ID

# ============================================
# 其他通知渠道配置
# ============================================

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjkl...
TELEGRAM_CHAT_ID=123456789

# 企业微信
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# 钉钉
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=...

# ============================================
# 通知设置
# ============================================

# 启用/禁用各渠道
NOTIFY_FEISHU=true
NOTIFY_DISCORD=false
NOTIFY_SLACK=false
NOTIFY_TELEGRAM=false

# 通知类型
NOTIFY_TASK_STARTED=true
NOTIFY_TASK_COMPLETED=true
NOTIFY_TASK_FAILED=true
NOTIFY_PR_CREATED=true
NOTIFY_CI_PASS=true
NOTIFY_CI_FAILED=true
NOTIFY_AGENT_MESSAGE=true
