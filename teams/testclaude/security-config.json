{
  "name": "Security Agent",
  "description": "负责安全审计、漏洞检测和依赖安全检查",
  "label": "security-agent",
  "runtime": "subagent",
  "mode": "session",
  "model": "claude-web/claude-sonnet-4-6",
  "thinking": "normal",
  "timeoutSeconds": 1800,
  "task": "You are a security agent. Your role is to identify security vulnerabilities, audit dependencies, and ensure secure coding practices.",
  "systemPrompt": "你是安全专家，负责识别和修复安全漏洞。",
  "communication": {
    "canSendTo": [
      "orchestrator",
      "coding-agent"
    ],
    "canReceiveFrom": [
      "orchestrator"
    ]
  },
  "tools": [
    "broadcast_to_agents",
    "get_task",
    "log_error",
    "log_info",
    "log_warning",
    "process_messages",
    "receive_messages",
    "run_security_scan",
    "send_notification",
    "send_to_agent",
    "update_task_status"
  ],
  "toolConfig": {
    "run_security_scan": {
      "script": "scripts/lib/agent-tools.sh",
      "function": "run_security_scan",
      "description": "运行安全扫描",
      "parameters": [
        "project-dir",
        "scan-type"
      ],
      "usage": "run_security_scan <project-dir> [all|dependencies|code]"
    },
    "log_info": {
      "script": "scripts/lib/common.sh",
      "function": "log_info",
      "description": "记录信息日志",
      "usage": "log_info <message>"
    },
    "log_warning": {
      "script": "scripts/lib/common.sh",
      "function": "log_warning",
      "description": "记录警告日志",
      "usage": "log_warning <message>"
    },
    "log_error": {
      "script": "scripts/lib/common.sh",
      "function": "log_error",
      "description": "记录错误日志",
      "usage": "log_error <message>"
    },
    "send_notification": {
      "script": "scripts/lib/notify.sh",
      "function": "send_notification",
      "description": "发送通知",
      "usage": "send_notification <channel> <message> [title]"
    },
    "get_task": {
      "script": "scripts/lib/common.sh",
      "function": "get_task",
      "description": "获取任务信息",
      "usage": "get_task <task-id>"
    },
    "update_task_status": {
      "script": "scripts/lib/common.sh",
      "function": "update_task_status",
      "description": "更新任务状态",
      "usage": "update_task_status <task-id> <status>"
    }
  },
  "capabilities": [
    "vulnerability-scanning",
    "dependency-check",
    "security-audit",
    "secret-detection"
  ],
  "persistence": {
    "storeMemory": true,
    "memoryFile": "memory/security-memory.md"
  }
}
